{
	"name": "fs-ext-extra-prebuilt",
	"description": "Fork of fs-ext with prebuilt binaries and Windows LockFileEx support.",
	"keywords": [
		"fs",
		"filesystem",
		"flock",
		"seek",
		"lockfileex",
		"prebuilt"
	],
	"version": "2.2.7",
	"homepage": "https://github.com/adamziel/fs-ext-prebuilt",
	"repository": {
		"type": "git",
		"url": "git://github.com/adamziel/fs-ext-prebuilt.git"
	},
	"author": "WordPress Playground team",
	"contributors": [
		"Matt Sergeant <helpme@gmail.com> (http://baudehlo.wordpress.com/)"
	],
	"main": "dist/fs-ext.js",
	"types": "dist/fs-ext.d.ts",
	"files": [
		"dist/",
		"load-prebuilt.js",
		"install.js",
		"binaries/",
		"binding.gyp",
		"fs-ext.cc",
		"LICENSE.txt"
	],
	"engines": {
		"node": ">= 8.0.0"
	},
	"dependencies": {
		"nan": "^2.24.0"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/adamziel/fs-ext-prebuilt/issues"
	},
	"scripts": {
		"build": "tsc",
		"build:workers": "tsc -p tsconfig.workers.json",
		"prepublishOnly": "npm run build",
		"prebuilds": "node ./prebuildify.js",
		"install": "node ./install.js",
		"test": "npm run build && npm run build:workers && npx tsx ./run_tests.ts && npm run test:jest",
		"test:jest": "jest tests/fcntl-range-locks.test.ts",
		"lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"*.js\"",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.workers.json"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.2",
		"@typescript-eslint/eslint-plugin": "^8.49.0",
		"@typescript-eslint/parser": "^8.49.0",
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"node-abi": "^3.85.0",
		"node-gyp": "^11.2.0",
		"prebuildify": "^6.0.1",
		"ts-jest": "^29.4.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
